{
  "info": {
    "name": "Smart Campus API",
    "description": "Postman collection for Smart Campus API (discovery, rooms, sensors, readings)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/Smart_Campus_API_20231548_CSA_CW/api/v1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Discovery - GET /",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/",
          "host": [
            "{{baseUrl}}/"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Response is JSON', function () { pm.response.to.have.header('Content-Type'); pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json'); });",
              "pm.test('Body parses to object', function () { pm.expect(() => pm.response.json()).not.to.throw(); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Get all rooms - GET /rooms",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/rooms",
          "host": [
            "{{baseUrl}}/rooms"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('JSON array returned', function () { var json = pm.response.json(); pm.expect(Array.isArray(json)).to.be.true; });"
            ]
          }
        }
      ]
    },
    {
      "name": "Create room - POST /rooms (LIB-301)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": \"LIB-301\",\n  \"name\": \"Library Room 301\",\n  \"floor\": \"3\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/rooms",
          "host": [
            "{{baseUrl}}/rooms"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201', function () { pm.response.to.have.status(201); });",
              "pm.test('Location header present', function () { pm.expect(pm.response.headers.has('Location')).to.be.true; });",
              "pm.test('Response contains created id', function () { var json = pm.response.json(); pm.expect(json.id).to.eql('LIB-301'); });"
            ]
          }
        }
      ]
    },
